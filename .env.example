# ── MUSIC ──────────────────────────────────────────────
# Path to your music directory (absolute path on host)
MUSIC_DIR=./music

# ── NAVIDROME ──────────────────────────────────────────
NAVIDROME_PORT=4533
NAVIDROME_USER=admin
NAVIDROME_PASS=changeme

# ── API ────────────────────────────────────────────────
API_PORT=8000
JWT_SECRET=change-this-to-a-random-secret-string
ENV=production

# ── FRONTEND ───────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000
VITE_NAVIDROME_URL=http://localhost:4533

# ── OLLAMA ─────────────────────────────────────────────
OLLAMA_PORT=11434
# Options: gemma2:2b (fast), gemma2:9b (best quality), llama3.2:3b
OLLAMA_MODEL=gemma2:9b

# ── QDRANT ─────────────────────────────────────────────
QDRANT_PORT=6333

# ── REDIS ──────────────────────────────────────────────
REDIS_PORT=6379

# ── POSTGRES ───────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_DB=driftwave
POSTGRES_USER=driftwave
POSTGRES_PASSWORD=driftwave

# ── INDEXER ────────────────────────────────────────────
# Number of parallel workers for librosa audio analysis
LIBROSA_WORKERS=4
# Seconds of audio to analyze per track (30 = fast, 90 = accurate)
ANALYSIS_DURATION=30
# AcoustID API key (free at acoustid.org) - for fingerprint detection
ACOUSTID_KEY=
# Genius API key (free at genius.com/api-clients) - for lyrics
GENIUS_KEY=
